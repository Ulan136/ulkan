// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Пользователи (админы) ────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin") // admin | super_admin | responsible
  slug      String?  @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── Клиенты (заказчики) ─────────────────────────────────────────────────
model Client {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  phone     String?
  createdAt DateTime @default(now())
  orders    Order[]
}

// ─── Поставщики ───────────────────────────────────────────────────────────
model Supplier {
  id        String     @id @default(cuid())
  name      String     @unique
  type      String     @default("Внешний") // Внешний | Внутренний склад
  active    Boolean    @default(true)
  positions Position[]
}

// ─── Номенклатура ─────────────────────────────────────────────────────────
model Nomenclature {
  id   String @id @default(cuid())
  name String // Наименование 1С
  unit String @default("шт")
  cat  String @default("")
}

// ─── Проекты ──────────────────────────────────────────────────────────────
model Project {
  id        String   @id // PRJ-xxx-DDHHMMYY
  name      String
  clientId  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  orders    Order[]
}

// ─── Заказы (CardID = C-xxx-DDHHMMYY) ────────────────────────────────────
model Order {
  id           String     @id // C-xxx-DDHHMMYY
  fromId       String?
  from         String     // Имя заказчика
  to           String     @default("")
  screen       String     @default("incoming")
  // incoming | reception | outgoing | accounting | bookkeeping | archive
  block        String     @default("") // waiting | processing | ""
  status       String     @default("В ожидании")
  source       String     @default("cabinet")
  // cabinet | external | webhook | admin_manual | responsible_portal
  projectId    String?
  comment      String     @default("")
  phone        String?
  deadline     DateTime?
  delivered    DateTime?
  isDraft      Boolean    @default(false)
  isChanged    Boolean    @default(false)
  changeText   String     @default("")
  changePhone  String     @default("")
  isCancelled  Boolean    @default(false)
  cancelReason String     @default("")
  toacc        Boolean    @default(false)
  postponed    Boolean    @default(false)
  invoice      Boolean    @default(false)
  fact         Boolean    @default(false)
  posted1C     Boolean    @default(false)
  trackingLink String     @default("")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  client    Client?    @relation(fields: [fromId], references: [id])
  project   Project?   @relation(fields: [projectId], references: [id])
  positions Position[]
  history   History[]
}

// ─── Позиции ──────────────────────────────────────────────────────────────
model Position {
  id         String   @id // CardID-Pn
  cardId     String
  name1c     String   @default("")
  oral       String   @default("")
  qty        Float    @default(0)
  unit       String   @default("шт")
  price      Float    @default(0)
  resp       String   @default("")
  supplierId String?
  supplier   String   @default("")
  status     String   @default("В работе")
  // В работе | Готово к отгрузке | В пути | Доставлено
  late       Boolean  @default(false)
  payment    String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  order     Order     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  supplierR Supplier? @relation(fields: [supplierId], references: [id])
}

// ─── История (лог действий) ───────────────────────────────────────────────
model History {
  id        String   @id @default(cuid())
  cardId    String
  action    String
  detail    String   @default("")
  userId    String?
  userName  String   @default("Система")
  createdAt DateTime @default(now())

  order Order @relation(fields: [cardId], references: [id], onDelete: Cascade)
}
